generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SeasonStatus {
  DRAFT
  CURRENT
  CLOSED
}

enum RaceStatus {
  DRAFT
  OPEN
  PENDING
  RUNNING
  FINISHED
}

enum RaceType {
  SINGLE
  STAGE
}

enum TeamStrategy {
  GENERAL_CLASSIFICATION
  SPRINT_STAGE
  BREAKAWAY
  BALANCED
}

enum SegmentType {
  flat
  climb
  descent
}

enum WindDirection {
  head
  tail
  cross
}

enum CyclistRole {
  LEADER
  DOMESTIQUE
  SPRINTER
  CLIMBER
  ROULEUR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Season {
  id         String       @id @default(uuid())
  year       Int          @unique
  status     SeasonStatus @default(DRAFT)
  createdAt  DateTime     @default(now())

  races      Race[]
  raceGroups RaceGroup[]

  @@map("seasons")
}

model RaceGroup {
  id        String   @id @default(uuid())
  name      String
  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id])
  createdAt DateTime @default(now())

  stages Race[]

  @@map("race_groups")
}

model Team {
  id            String       @id @default(uuid())
  name          String
  townName      String?
  managerName   String?
  strategy      TeamStrategy
  leaderId      String
  domestiqueIds String[]
  createdAt     DateTime     @default(now())

  cyclists    Cyclist[]
  raceTeams   RaceTeam[]
  raceEntries RaceEntry[]
  owner       User?

  @@map("teams")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  teamId    String?  @unique
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Cyclist {
  id          String   @id @default(uuid())
  name        String
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  stamina     Int
  performance Int
  climbing    Int
  sprint      Int
  vigilance   Int
  resistance  Int
  recovery    Int
  createdAt   DateTime @default(now())

  cyclistSnapshots CyclistSnapshot[]
  raceEntries      RaceEntry[]

  @@map("cyclists")
}

model Race {
  id            String     @id @default(uuid())
  name          String
  totalDistance Float
  status        RaceStatus @default(DRAFT)
  seed          Int?
  cyclistIds    String[]   @default([])
  raceType      RaceType   @default(SINGLE)
  stageNumber   Int?
  seasonId      String?
  raceGroupId   String?
  createdAt     DateTime   @default(now())
  finishedAt    DateTime?

  season      Season?     @relation(fields: [seasonId], references: [id])
  raceGroup   RaceGroup?  @relation(fields: [raceGroupId], references: [id])
  segments    Segment[]
  raceTeams   RaceTeam[]
  raceEntries RaceEntry[]
  snapshots   RaceSnapshot[]

  @@map("races")
}

model RaceEntry {
  id        String      @id @default(uuid())
  raceId    String
  race      Race        @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team        @relation(fields: [teamId], references: [id])
  cyclistId   String
  cyclist     Cyclist     @relation(fields: [cyclistId], references: [id])
  startNumber Int?
  isLeader    Boolean     @default(false)
  role        CyclistRole

  @@unique([raceId, cyclistId])
  @@map("race_entries")
}

model RaceTeam {
  raceId String
  teamId String
  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])

  @@id([raceId, teamId])
  @@map("race_teams")
}

model Segment {
  id            String        @id @default(uuid())
  raceId        String
  race          Race          @relation(fields: [raceId], references: [id], onDelete: Cascade)
  startKm       Float
  endKm         Float
  type          SegmentType
  gradient      Float
  windDirection WindDirection?
  windStrength  Float?

  @@map("segments")
}

model RaceSnapshot {
  id     String @id @default(uuid())
  raceId String
  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  km     Float

  cyclistSnapshots CyclistSnapshot[]

  @@unique([raceId, km])
  @@index([raceId])
  @@map("race_snapshots")
}

model CyclistSnapshot {
  id         String       @id @default(uuid())
  snapshotId String
  snapshot   RaceSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  cyclistId  String
  cyclist    Cyclist      @relation(fields: [cyclistId], references: [id])
  position   Float
  speed      Float
  energy     Float
  fatigue    Float
  intent         String?
  groupId        String?
  isDropped      Boolean @default(false)
  finishPosition Int?

  @@index([snapshotId])
  @@map("cyclist_snapshots")
}
